{
  "title": "Gamma",
  "sfSymbol": "chart.line.uptrend.xyaxis",
  "summary": "Applies a per-channel power curve (1/gamma) to RGB. 1 = unchanged, >1 lifts midtones, <1 darkens.",
  "inputs": [
    { "name": "input", "type": "texture" },
    {
      "name": "gamma",
      "type": "float",
      "default": { "type": "float", "value": 1.0 },
      "ui": { "kind": "slider", "min": 0.1, "max": 3.0, "step": 0.01 }
    }
  ],
  "outputs": [
    { "name": "output", "type": "texture", "display": true }
  ]
}

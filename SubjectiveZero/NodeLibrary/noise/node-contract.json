{
  "title": "Noise",
  "sfSymbol": "aqi.medium",
  "summary": "Generates animated procedural noise (white, value, fractal fBm, or voronoi) as a grayscale texture source. No input.",
  "inputs": [
    {
      "name": "type",
      "type": "enum",
      "default": { "type": "enum", "value": "value" },
      "ui": { "kind": "dropdown" },
      "options": [ ["White", "white"], ["Value", "value"], ["Fractal", "fractal"], ["Voronoi", "voronoi"] ]
    },
    {
      "name": "scale",
      "type": "float",
      "default": { "type": "float", "value": 4.0 },
      "ui": { "kind": "slider", "min": 0.5, "max": 32.0, "step": 0.1 }
    },
    {
      "name": "speed",
      "type": "float",
      "default": { "type": "float", "value": 0.0 },
      "ui": { "kind": "slider", "min": 0.0, "max": 5.0, "step": 0.1 }
    },
    {
      "name": "octaves",
      "type": "float",
      "default": { "type": "float", "value": 4.0 },
      "ui": { "kind": "slider", "min": 1.0, "max": 8.0, "step": 1.0 }
    }
  ],
  "outputs": [
    { "name": "output", "type": "texture", "display": true }
  ]
}

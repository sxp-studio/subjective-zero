{
  "title": "Gaussian Blur",
  "sfSymbol": "drop.fill",
  "summary": "Separable 9-tap Gaussian blur. `radius` scales the tap spacing (0 = unchanged).",
  "inputs": [
    { "name": "input", "type": "texture" },
    {
      "name": "radius",
      "type": "float",
      "default": { "type": "float", "value": 3.0 },
      "ui": { "kind": "slider", "min": 0.0, "max": 20.0, "step": 0.1 }
    }
  ],
  "outputs": [
    { "name": "output", "type": "texture", "display": true }
  ]
}
